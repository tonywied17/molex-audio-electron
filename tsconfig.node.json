{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "package.json",
    "src/main/**/*",
    "src/preload/**/*"
  ],
  "exclude": ["out", "dist", "node_modules"],
  "compilerOptions": {
    "composite": true,
    "outDir": "./out",
    "types": ["node"]
  }
}
